# LLM Providers: choose one or configure all for runtime switching.
# Supported: openai, gemini, claude, deepseek, kimi, glm, qwen, minimax

## OpenAI (default fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

## Google Gemini
GEMINI_API_KEY=

## Anthropic Claude
ANTHROPIC_API_KEY=

## DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

## Moonshot (Kimi)
MOONSHOT_API_KEY=
# or alias: KIMI_API_KEY=

## Zhipu (GLM)
ZHIPU_API_KEY=
# or alias: GLM_API_KEY=

## Alibaba DashScope (Qwen)
DASHSCOPE_API_KEY=
# or alias: QWEN_API_KEY=

## MiniMax (uses Anthropic-compatible endpoint)
# Endpoint: https://api.minimaxi.com/anthropic/v1/messages
MINIMAX_API_KEY=
# or alias: MINIMAX_API_TOKEN=

## Web Search (optional)
TAVILY_API_KEY=
BRAVE_API_KEY=
EXA_API_KEY=
